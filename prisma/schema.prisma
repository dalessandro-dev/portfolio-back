generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  @@map("users")
}

model Stack {
  id       Int                @id @default(autoincrement())
  name     String
  projects ProjectsOnStacks[]

  @@map("stacks")
}

model Project {
  id          Int                @id @default(autoincrement())
  title       String
  description String
  videoUrl    String             @map("video_url")
  coverUrl    String             @map("cover_url")
  projectUrl  String             @map("project_url")
  githubUrl   String             @map("github_url")
  stacks      ProjectsOnStacks[]

  @@map("projects")
}

model ProjectsOnStacks {
  projectId Int     @map("project_id")
  stackId   Int     @map("stack_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stack     Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)

  @@id([projectId, stackId])
  @@map("projects_on_stacks")
}
